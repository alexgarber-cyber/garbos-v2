{
  "manifest_version": 3,
  "name": "GarbOS LinkedIn Importer",
  "version": "1.0.0",
  "description": "Import LinkedIn profiles into GarbOS with one click.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://garbos.io/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
