# ---- Postgres ----
# NOTE: garbos/garbos are LOCAL-DEV ONLY and are public (this repo is public).
# On the server, set a strong unique POSTGRES_PASSWORD and matching DATABASE_URL.
POSTGRES_USER=garbos
POSTGRES_PASSWORD=garbos
POSTGRES_DB=garbos
POSTGRES_PORT=5432
# Host interface the published DB port binds to. Defaults to loopback so the DB
# is NOT reachable from the LAN. Only change if you truly need remote access.
POSTGRES_BIND=127.0.0.1

# ---- API ----
# Inside the compose network the DB host is the service name "db".
DATABASE_URL=postgresql+psycopg://garbos:garbos@db:5432/garbos
# Set ENVIRONMENT=production on the server. Any non-"development" value makes the
# API refuse to boot while SEED_USER_PASSWORD / DATABASE_URL still hold the
# public defaults above — a guard against shipping known credentials.
ENVIRONMENT=development
# Cookie Secure flag — keep false on http, true behind HTTPS in prod.
COOKIE_SECURE=false
SESSION_TTL_HOURS=720

# CORS origin — must match the URL the *browser* uses to reach the web app.
#   Local dev:  http://localhost:3000
#   LAN server: http://192.168.0.45:3000   ← replace with your server's LAN IP
WEB_ORIGIN=http://localhost:3000

# ---- Single-user seed ----
# Use a real TLD — email-validator rejects reserved domains like ".local".
SEED_USER_EMAIL=alex@garbos.app
SEED_USER_PASSWORD=changeme-please

# ---- Web ----
# NEXT_PUBLIC_API_BASE_URL — URL the *browser* uses to reach the API.
#   Local dev:  http://localhost:8000
#   LAN server: http://192.168.0.45:8000   ← replace with your server's LAN IP
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# API_BASE_URL_INTERNAL — URL the Next.js *server* uses to reach the API
# (compose internal DNS — never change this for Docker deployments).
API_BASE_URL_INTERNAL=http://api:8000

# ---- IMAP polling (inbound/outbound email logging) ----
# Poll a dedicated mailbox every IMAP_POLL_INTERVAL_MINUTES; match senders/recipients
# to contacts and auto-log Email activities. Leave IMAP_ENABLED=false to disable.
# Use an app-specific password (never the account password), and set real values
# only in the server .env — never commit credentials.
IMAP_ENABLED=false
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
IMAP_MAILBOX=INBOX
IMAP_POLL_INTERVAL_MINUTES=5
